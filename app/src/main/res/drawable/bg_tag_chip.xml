<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradient background -->
    <gradient
        android:startColor="#1F1C2C"
        android:endColor="#928DAB"
        android:angle="45"/>

    <!-- Rounded corners -->
    <corners android:radius="20dp"/>

    <!-- Padding -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="6dp"
        android:bottom="6dp"/>

    <!-- Subtle border -->
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF"/>

</shape>
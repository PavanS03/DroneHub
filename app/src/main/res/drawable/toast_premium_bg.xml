<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradient -->
    <gradient
        android:startColor="#7B1FA2"
        android:endColor="#FF6F00"
        android:angle="45" />

    <!-- Rounded corners -->
    <corners android:radius="24dp" />

    <!-- Padding -->
    <padding
        android:left="20dp"
        android:right="20dp"
        android:top="12dp"
        android:bottom="12dp" />

    <!-- Stroke -->
    <stroke
        android:width="2dp"
        android:color="#FFFFFF" />

</shape>
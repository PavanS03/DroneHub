<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 🔥 BASE GLASS (dark card) -->
    <item>
        <shape>
            <solid android:color="#2C2C2C"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- ✨ INNER LIGHT GRADIENT (bright red accent glow) -->
    <item>
        <shape>
            <gradient
                android:startColor="#40FF3B3B"
                android:endColor="@android:color/transparent"
                android:angle="270"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- 🔴 NEON BORDER (accent red stroke) -->
    <item>
        <shape>
            <stroke
                android:width="1.5dp"
                android:color="#FF3B3B"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

</layer-list>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ⚫ BASE GLASS (dark card) -->
    <item>
        <shape>
            <solid android:color="#2A2A2A"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- ✨ INNER LIGHT GRADIENT (teal accent glow) -->
    <item>
        <shape>
            <gradient
                android:startColor="#4003DAC6"
                android:endColor="@android:color/transparent"
                android:angle="270"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- 🟢 NEON BORDER (accent teal stroke) -->
    <item>
        <shape>
            <stroke
                android:width="1.5dp"
                android:color="#03DAC6"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

</layer-list>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 🌌 BASE GLASS -->
    <item>
        <shape>
            <solid android:color="#14FFFFFF"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- ✨ INNER LIGHT GRADIENT -->
    <item>
        <shape>
            <gradient
                android:startColor="#40C77DFF"
                android:endColor="@android:color/transparent"
                android:angle="270"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- 🔵 NEON BORDER -->
    <item>
        <shape>
            <stroke
                android:width="1.5dp"
                android:color="#669D4EDD"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

</layer-list>
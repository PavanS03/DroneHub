<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 🔥 PRESSED STATE -->
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#4A7CFF"
                android:endColor="#8B5CF6"
                android:angle="45"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- 🌈 DEFAULT -->
    <item>
        <shape>
            <gradient
                android:startColor="#5B8CFF"
                android:endColor="#9F7AEA"
                android:angle="45"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

</selector>
<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetStart="@id/start"
        motion:constraintSetEnd="@id/end"
        motion:duration="1200"
        motion:staggered="0.3">

        <OnSwipe
            motion:touchAnchorId="@id/mainContent"
            motion:touchAnchorSide="top"
            motion:dragDirection="dragUp"
            motion:dragScale="0.5" />

        <OnClick motion:targetId="@id/cardRevenue" />

    </Transition>

    <ConstraintSet android:id="@id/start">

        <Constraint android:id="@id/greetingContainer">
            <PropertySet android:alpha="0.0" />
            <Transform android:scaleX="0.8" android:scaleY="0.8" />
            android:layout_marginTop="50dp"
        </Constraint>

        <Constraint android:id="@id/cardRevenue">
            <PropertySet android:alpha="0.0" />
            android:layout_marginTop="100dp"
        </Constraint>

        <Constraint android:id="@id/statsGrid">
            <PropertySet android:alpha="0.0" />
            android:layout_marginTop="80dp"
        </Constraint>

    </ConstraintSet>

    <ConstraintSet android:id="@id/end">

        <Constraint android:id="@id/greetingContainer">
            <PropertySet android:alpha="1.0" />
            <Transform android:scaleX="1.0" android:scaleY="1.0" />
            android:layout_marginTop="0dp"
        </Constraint>

        <Constraint android:id="@id/cardRevenue">
            <PropertySet android:alpha="1.0" />
            android:layout_marginTop="0dp"
        </Constraint>

        <Constraint android:id="@id/statsGrid">
            <PropertySet android:alpha="1.0" />
            android:layout_marginTop="0dp"
        </Constraint>

    </ConstraintSet>

    <KeyFrameSet>

        <KeyAttribute
            motion:motionTarget="@id/greetingContainer"
            motion:framePosition="25"
            android:alpha="0.7"
            android:scaleX="1.05"
            android:scaleY="1.05" />

        <KeyAttribute
            motion:motionTarget="@id/cardRevenue"
            motion:framePosition="50"
            android:alpha="0.8" />

        <KeyAttribute
            motion:motionTarget="@id/statsGrid"
            motion:framePosition="75"
            android:alpha="0.5" />

    </KeyFrameSet>

</MotionScene>
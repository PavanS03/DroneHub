<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="10dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/electric_blue"
    android:background="@drawable/bg_glass_card_blue"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/btnDelete">

                <ImageView
                    android:id="@+id/imgSector"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_dronehub"
                    android:background="@drawable/bg_premium_layer"
                    android:padding="4dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvSectorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sector Name"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#B3FFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/bg_glass_card"
                app:tint="#FF5252"
                android:clickable="true"
                android:focusable="true"/>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="14dp"
            android:background="#22FFFFFF"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAvailable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sector Available"
            android:textColor="@color/white"
            android:thumbTint="@color/electric_blue"
            android:trackTint="#33FFFFFF"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchUserVisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Visible To Users"
            android:textColor="@color/white"
            android:thumbTint="@color/electric_blue"
            android:trackTint="#33FFFFFF"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
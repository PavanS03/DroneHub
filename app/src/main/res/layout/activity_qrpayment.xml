<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="#0F0F1E"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹ 0"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#00F2FF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Required"
        android:textSize="18sp"
        android:textColor="#B3FFFFFF"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeColor="#33FFFFFF"
        app:strokeWidth="1dp"
        android:layout_marginBottom="40dp">

        <ImageView
            android:id="@+id/imgQR"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/sample_qr"/>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPaymentDone"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="I HAVE PAID"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000000"
        app:backgroundTint="#00F2FF"
        app:cornerRadius="12dp"
        android:layout_marginTop="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Click after completing the transaction"
        android:textColor="#80FFFFFF"
        android:textSize="14sp"
        android:layout_marginTop="12dp"/>

</LinearLayout>
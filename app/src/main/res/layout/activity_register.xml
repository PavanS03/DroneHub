<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glass_card_blue">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_glow_overlay"
        android:alpha="0.25"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_dronehub"
                android:contentDescription="Logo"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Drone Hub"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_gravity="center"
                android:letterSpacing="0.05"
                android:alpha="1.0"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create your futuristic account"
                android:textSize="14sp"
                android:textColor="#B0FFFFFF"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:alpha="1.0"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="16dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:strokeColor="#33FFFFFF"
                app:strokeWidth="1dp"
                android:translationY="0dp"
                android:alpha="1.0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:hint="👤 Full Name"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="#00B8D4"
                        app:boxBackgroundColor="#1AFFFFFF"
                        app:hintTextColor="#80FFFFFF">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColorHint="#80FFFFFF"
                            android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:hint="📧 Email"
                        app:boxStrokeColor="#00B8D4"
                        app:boxBackgroundColor="#1AFFFFFF"
                        app:hintTextColor="#80FFFFFF">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#80FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:hint="🔒 Password"
                        app:endIconMode="password_toggle"
                        app:boxStrokeColor="#FF5722"
                        app:boxBackgroundColor="#1AFFFFFF"
                        app:hintTextColor="#80FFFFFF">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#80FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <ProgressBar
                        android:id="@+id/passwordStrength"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="6dp"
                        android:progressTint="#00E5FF"
                        android:progressBackgroundTint="#1AFFFFFF"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:hint="📱 Phone Number"
                        app:boxStrokeColor="#FF5722"
                        app:boxBackgroundColor="#1AFFFFFF"
                        app:hintTextColor="#80FFFFFF">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#80FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯 Select Role"
                        android:textColor="#00E5FF"
                        android:textStyle="bold"
                        android:layout_marginTop="18dp"/>

                    <RadioGroup
                        android:id="@+id/rgRole"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <RadioButton
                            android:id="@+id/rbCustomer"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Customer"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#00E5FF"/>

                        <RadioButton
                            android:id="@+id/rbAdmin"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Admin"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#00E5FF"/>
                    </RadioGroup>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegister"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="24dp"
                        android:text="🚀 Create Account"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#FF5722"
                        app:cornerRadius="22dp"/>

                    <TextView
                        android:id="@+id/tvLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already have an account? Login"
                        android:textColor="#00E5FF"
                        android:layout_gravity="center"
                        android:layout_marginTop="18dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
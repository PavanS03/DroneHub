<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="DashboardCardStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">140dp</item>
        <item name="android:layout_margin">12dp</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">24dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:elevation">20dp</item>
        <item name="android:foreground">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="DroneCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">20dp</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">24dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/accent_glow</item>
        <item name="strokeWidth">2dp</item>
        <item name="rippleColor">@color/accent_glow</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackgroundBorderless</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>